# Copy this file to .env and fill in your values
# Both backend and agent read this file automatically on startup

# OpenAI API key — required for AI-powered test case generation and execution verdicts
# Get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI webhook signing secret — set this after creating the webhook in OpenAI dashboard
OPENAI_WEBHOOK_SECRET=whsec_your_openai_webhook_secret_here

# Public HTTPS base URL for your backend when exposed through ngrok / Cloudflare Tunnel
# Example: https://your-subdomain.ngrok-free.app
BACKEND_PUBLIC_BASE_URL=



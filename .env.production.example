# Copy to .env on the Hostinger VPS and replace placeholder values.

# Public domain used by Nginx and API callbacks
PUBLIC_DOMAIN=example.com

# Database
POSTGRES_DB=ste_platform
POSTGRES_USER=ste_user
POSTGRES_PASSWORD=change_me
DATABASE_URL=postgresql+psycopg://ste_user:change_me@postgres:5432/ste_platform

# Service URLs
AGENT_BASE_URL=http://agent:8010
BACKEND_PUBLIC_BASE_URL=https://example.com
VITE_API_BASE_URL=https://example.com/api/v1

# OpenAI
OPENAI_API_KEY=
OPENAI_WEBHOOK_SECRET=

